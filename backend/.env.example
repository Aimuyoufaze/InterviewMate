DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 语音转文字 (STT) ──
# 默认使用本地 Whisper（离线），推荐国内用户改用百度语音识别：

# 方案一：百度语音识别 (国内推荐)
# 配置 BAIDU_STT_API_KEY + BAIDU_STT_SECRET_KEY 即可自动启用（无需设置 STT_PROVIDER）
# STT_PROVIDER=baidu  # 可选：显式指定百度
# BAIDU_STT_APP_ID=你的AppID
# BAIDU_STT_API_KEY=你的API_Key
# BAIDU_STT_SECRET_KEY=你的Secret_Key
# （从 https://console.bce.baidu.com/ai/#/ai/speech/overview/index 获取）
# BAIDU_STT_DEV_PID=1537  # 模型: 1537=普通话, 1737=英语

# 方案二：OpenAI 兼容 Whisper API (Groq/OpenAI 等)
# STT_API_KEY=sk-...
# STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
# STT_MODEL=whisper-large-v3

# 方案三：本地 Whisper（无需配置，首次自动下载模型）
# WHISPER_MODEL=base  # tiny / base / small / medium / large-v3
